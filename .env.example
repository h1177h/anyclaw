# AnyClaw environment variables
#
# Use this as a template for environment variables you export before running
# AnyClaw. It also includes the Docker Compose variable names read by
# docker-compose.yml.
# The AnyClaw CLI does not automatically load `.env` files by itself.
# Empty values mean "leave disabled / use config file value".

# -----------------------------------------------------------------------------
# Core LLM overrides
# -----------------------------------------------------------------------------
# Provider examples: openai, anthropic, qwen, ollama, compatible
LLM_PROVIDER=
# Model examples: gpt-4o-mini, claude-sonnet-4-7, qwen-max, llama3.2
LLM_MODEL=
# Use this for compatible or self-hosted endpoints.
LLM_BASE_URL=

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Docker Compose LLM overrides
# -----------------------------------------------------------------------------
# docker-compose.yml reads these names from `.env`.
ANYCLAW_LLM_PROVIDER=
ANYCLAW_LLM_MODEL=
ANYCLAW_LLM_API_KEY=

# -----------------------------------------------------------------------------
# Gateway overrides
# -----------------------------------------------------------------------------
# Host example: 127.0.0.1
ANYCLAW_GATEWAY_HOST=
# Bind examples: loopback, all, 127.0.0.1, 0.0.0.0
ANYCLAW_GATEWAY_BIND=
# Port example: 18789
ANYCLAW_GATEWAY_PORT=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Optional API token used to protect HTTP endpoints.
ANYCLAW_API_TOKEN=
# Optional shared secret for signed ingress / webhooks.
ANYCLAW_WEBHOOK_SECRET=
# Requests per minute, example: 120
ANYCLAW_RATE_LIMIT_RPM=
# Plugin execution timeout in seconds, example: 10
ANYCLAW_PLUGIN_EXEC_TIMEOUT=

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
ANYCLAW_TELEGRAM_BOT_TOKEN=
ANYCLAW_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
ANYCLAW_SLACK_BOT_TOKEN=
ANYCLAW_SLACK_APP_TOKEN=
ANYCLAW_SLACK_DEFAULT_CHANNEL=

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
ANYCLAW_DISCORD_BOT_TOKEN=
ANYCLAW_DISCORD_DEFAULT_CHANNEL=
ANYCLAW_DISCORD_API_BASE_URL=
ANYCLAW_DISCORD_GUILD_ID=
ANYCLAW_DISCORD_PUBLIC_KEY=
# true / false
ANYCLAW_DISCORD_USE_GATEWAY_WS=

# -----------------------------------------------------------------------------
# WhatsApp
# -----------------------------------------------------------------------------
ANYCLAW_WHATSAPP_ACCESS_TOKEN=
ANYCLAW_WHATSAPP_PHONE_NUMBER_ID=
ANYCLAW_WHATSAPP_VERIFY_TOKEN=
ANYCLAW_WHATSAPP_APP_SECRET=
ANYCLAW_WHATSAPP_DEFAULT_RECIPIENT=

# -----------------------------------------------------------------------------
# Signal
# -----------------------------------------------------------------------------
ANYCLAW_SIGNAL_BASE_URL=
ANYCLAW_SIGNAL_NUMBER=
ANYCLAW_SIGNAL_DEFAULT_RECIPIENT=
ANYCLAW_SIGNAL_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Control UI
# -----------------------------------------------------------------------------
# Override web control UI build root, example: D:\anyclaw\dist\control-ui
ANYCLAW_CONTROL_UI_ROOT=

# -----------------------------------------------------------------------------
# Advanced / optional
# -----------------------------------------------------------------------------
# Secrets manager encryption key
ANYCLAW_SECRETS_KEY=
# Secrets fallback prefix used by runtime snapshots
# Example runtime secret variable name: ANYCLAW_SECRET_OPENAI_API_KEY
# ANYCLAW_SECRET_EXAMPLE=
