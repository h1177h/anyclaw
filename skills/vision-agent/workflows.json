{
  "name": "vision-agent",
  "description": "Reviewed desktop vision workflows for AnyClaw",
  "version": "1.0.0",
  "workflows": {
    "launch_app": {
      "description": "Launch an application and verify it opened",
      "steps": [
        {"tool": "desktop_open", "params": {"target": "notepad.exe", "kind": "app"}},
        {"tool": "desktop_wait", "params": {"wait_ms": 1000}},
        {"tool": "desktop_screenshot", "params": {"path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_ocr", "params": {"path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_verify_text", "params": {"text": "Notepad", "scope": "screen"}}
      ]
    },
    "click_button": {
      "description": "Find and click a button by visible text",
      "steps": [
        {"tool": "desktop_screenshot", "params": {"path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_find_text", "params": {"text": "Save", "path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_click", "params": {"x": "{{find_text.x}}", "y": "{{find_text.y}}"}}
      ]
    },
    "type_text": {
      "description": "Click an input box and type sample text",
      "steps": [
        {"tool": "desktop_screenshot", "params": {"path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_find_text", "params": {"text": "Input", "path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_click", "params": {"x": "{{find_text.x}}", "y": "{{find_text.y}}"}},
        {"tool": "desktop_type_human", "params": {"text": "Hello World", "delay_ms": 50}}
      ]
    },
    "fill_form": {
      "description": "Fill a demo login form with caller-provided values",
      "steps": [
        {"tool": "desktop_screenshot", "params": {"path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_find_text", "params": {"text": "Username", "path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_click", "params": {"x": "{{find_text.x}}", "y": "{{find_text.y}}"}},
        {"tool": "desktop_type_human", "params": {"text": "{{username}}", "delay_ms": 30}},
        {"tool": "desktop_find_text", "params": {"text": "Password", "path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_click", "params": {"x": "{{find_text.x}}", "y": "{{find_text.y}}"}},
        {"tool": "desktop_type_human", "params": {"text": "{{credential}}", "delay_ms": 30}},
        {"tool": "desktop_find_text", "params": {"text": "Sign in", "path": ".anyclaw/vision/screen.png"}},
        {"tool": "desktop_click", "params": {"x": "{{find_text.x}}", "y": "{{find_text.y}}"}}
      ]
    }
  }
}
